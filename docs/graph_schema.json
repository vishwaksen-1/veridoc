{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Veridoc Graph JSON",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z0-9_]+$": {
      "type": "object",
      "properties": {
        "calls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of modules instantiated by this module"
        },
        "called_by": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of modules that instantiate this module"
        }
      },
      "required": ["calls", "called_by"]
    }
  },
  "additionalProperties": false
}
